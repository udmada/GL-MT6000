amends "@com.github.actions/Workflow.pkl"

import "@com.github.actions/Step.pkl"
import "@com.github.actions/catalog.pkl"

import "actions/MiseAction.pkl"

name = "Verify pkl-generated workflows"

on {
  // pull_request covers dependabot's action bumps: it rewrites the SHAs in
  // every generated workflow plus __lockfile__.yml in one PR, and this check
  // proves regeneration agrees with the committed YAML
  pull_request {}
  push {
    branches {
      "main"
    }
  }
}

permissions {
  contents = "read"
}

jobs {
  ["check"] {
    `runs-on` = "ubuntu-slim"
    steps {
      (catalog.`actions/checkout@v6`) {
        with {
          `fetch-depth` = 1
        }
      }
      (MiseAction) {
        with {
          experimental = true
        }
      }
      (Step) {
        name = "Verify pkl gen is up to date"
        run = "mise run pkl:gen && git diff --exit-code .github/"
      }
    }
  }
}
