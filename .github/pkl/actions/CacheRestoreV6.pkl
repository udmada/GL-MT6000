/// Restore Cache artifacts like dependencies and build outputs to improve workflow execution time
///
/// Local wrapper: the bundled com.github.actions catalog tops out at
/// actions/cache/restore@v5 — drop this module once it ships a v6 entry.
module actions.cache.restore.v6.CacheRestore

extends "@com.github.actions/AbstractTypedStep.pkl"

fixed action: "actions/cache/restore"

fixed version: "v6"

with: With?

class With {
  /// A list of files, directories, and wildcard patterns to restore
  hidden pathList: Listing<String>

  /// A list of files, directories, and wildcard patterns to restore
  ///
  /// To set as a [Listing], use [pathList].
  path: String = pathList.join("\n")

  /// An explicit key for restoring the cache
  key: String

  /// An ordered multiline string listing the prefix-matched keys, that are used for restoring stale cache if no cache hit occurred for key. Note `cache-hit` returns false in this case.
  hidden `restore-keys-list`: Listing<String>?

  /// An ordered multiline string listing the prefix-matched keys, that are used for restoring stale cache if no cache hit occurred for key. Note `cache-hit` returns false in this case.
  ///
  /// To set as a [Listing], use [`restore-keys-list`].
  `restore-keys`: String? = `restore-keys-list`?.join("\n")

  /// An optional boolean when enabled, allows windows runners to restore caches that were saved on other platforms
  ///
  /// Default if unspecified: `"false"`
  enableCrossOsArchive: Boolean?

  /// Fail the workflow if cache entry is not found
  ///
  /// Default if unspecified: `"false"`
  `fail-on-cache-miss`: Boolean?

  /// Check if a cache entry exists for the given input(s) (key, restore-keys) without downloading the cache
  ///
  /// Default if unspecified: `"false"`
  `lookup-only`: Boolean?
}
