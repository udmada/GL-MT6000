/// Save Cache artifacts like dependencies and build outputs to improve workflow execution time
///
/// Local wrapper: the bundled com.github.actions catalog tops out at
/// actions/cache/save@v5 — drop this module once it ships a v6 entry.
module actions.cache.save.v6.CacheSave

extends "@com.github.actions/AbstractTypedStep.pkl"

fixed action: "actions/cache/save"

fixed version: "v6"

with: With?

class With {
  /// A list of files, directories, and wildcard patterns to cache
  hidden pathList: Listing<String>

  /// A list of files, directories, and wildcard patterns to cache
  ///
  /// To set as a [Listing], use [pathList].
  path: String = pathList.join("\n")

  /// An explicit key for saving the cache
  key: String

  /// The chunk size used to split up large files during upload, in bytes
  `upload-chunk-size`: Int?

  /// An optional boolean when enabled, allows windows runners to save caches that can be restored on other platforms
  ///
  /// Default if unspecified: `"false"`
  enableCrossOsArchive: Boolean?
}
